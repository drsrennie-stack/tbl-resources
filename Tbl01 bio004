<header class="masthead">
  <div class="inner">
    <p class="brandline">MedMasters Launch Studio (A MedMasters Collaborative Company)</p>
    <h1>TBL #1: Intro, Tissues &amp; Integumentary</h1>
    <div class="meta-line">
      <span><span class="label">Course</span><b>BIOL OO4 Human Anatomy</b></span>
      <span><span class="label">Instructor</span><b>Dr. Rennie</b></span>

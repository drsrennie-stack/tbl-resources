<script>
(function(){
  "use strict";

  // ---------- Prework checkboxes with safe local persistence ----------
  var STORE_KEY = "tbl01_bio004_prework";
  function loadState(){
    try{ return JSON.parse(localStorage.getItem(STORE_KEY) || "{}"); }
    catch(e){ return {}; }
  }
  function saveState(state){
    try{ localStorage.setItem(STORE_KEY, JSON.stringify(state)); }
    catch(e){ /* storage blocked, degrade silently */ }
  }
  var state = loadState();
  var boxes = Array.prototype.slice.call(document.querySelectorAll('.pw-item input[type=checkbox]'));
  var progressTag = document.getElementById('pwProgress');

  function refreshProgress(){
    var done = boxes.filter(function(b){ return b.checked; }).length;
    progressTag.textContent = done + ' of ' + boxes.length + ' complete';
  }
  boxes.forEach(function(box){
    var item = box.closest('.pw-item');
    var id = box.id;
    if(state[id]){ box.checked = true; item.classList.add('done'); }
    box.addEventListener('change', function(){
      item.classList.toggle('done', box.checked);
      state[id] = box.checked;
      saveState(state);
      refreshProgress();
    });
  });
  refreshProgress();

  // ---------- Section navigation pills ----------
  document.querySelectorAll('.pill').forEach(function(pill){
    pill.addEventListener('click', function(){
      var id = pill.getAttribute('data-go');
      var el = document.getElementById(id) || document.getElementById(id + 'Section');
      if(el){ el.scrollIntoView({behavior:'smooth', block:'start'}); }
    });
  });

  // ---------- Phase timer ----------
  var readout = document.getElementById('timer');
  var startBtn = document.getElementById('timerStart');
  var resetBtn = document.getElementById('timerReset');
  var presets = Array.prototype.slice.call(document.querySelectorAll('.btn.preset'));
  var totalSeconds = 12 * 60;
  var remaining = totalSeconds;
  var ticking = false;
  var handle = null;

  function fmt(s){
    var m = Math.floor(s / 60);
    var sec = s % 60;
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }
  function render(){
    readout.textContent = fmt(remaining);
    readout.classList.toggle('warn', remaining <= 60);
  }
  function stop(){
    ticking = false; startBtn.textContent = 'Start';
    if(handle){ clearInterval(handle); handle = null; }
  }
  function start(){
    if(ticking || remaining <= 0) return;
    ticking = true; startBtn.textContent = 'Pause';
    handle = setInterval(function(){
      remaining = Math.max(0, remaining - 1);
      render();
      if(remaining === 0){ stop(); }
    }, 1000);
  }
  startBtn.addEventListener('click', function(){ ticking ? stop() : start(); });
  resetBtn.addEventListener('click', function(){ stop(); remaining = totalSeconds; render(); });
  presets.forEach(function(p){
    p.addEventListener('click', function(){
      presets.forEach(function(x){ x.classList.remove('active'); });
      p.classList.add('active');
      totalSeconds = parseInt(p.getAttribute('data-min'), 10) * 60;
      stop(); remaining = totalSeconds; render();
    });
  });
  render();

  // ---------- Answer center reveal ----------
  var revealBtn = document.getElementById('revealBtn');
  var center = document.getElementById('answerCenter');
  var revealBar = document.getElementById('revealBar');
  revealBtn.addEventListener('click', function(){
    var open = center.hasAttribute('hidden');
    if(open){
      center.removeAttribute('hidden');
      revealBtn.textContent = 'Hide instructor answer center';
      revealBtn.setAttribute('aria-expanded', 'true');
    } else {
      center.setAttribute('hidden', '');
      revealBtn.textContent = 'Reveal instructor answer center';
      revealBtn.setAttribute('aria-expanded', 'false');
    }
  });

  // ---------- Print scoping ----------
  var printStudent = document.getElementById('printStudent');
  var printFull = document.getElementById('printFull');
  printStudent.addEventListener('click', function(){
    document.body.classList.add('print-student');
    window.print();
  });
  printFull.addEventListener('click', function(){
    document.body.classList.remove('print-student');
    if(center.hasAttribute('hidden')){ center.removeAttribute('hidden');
      revealBtn.textContent = 'Hide instructor answer center';
      revealBtn.setAttribute('aria-expanded', 'true');
    }
    window.print();
  });
  window.addEventListener('afterprint', function(){
    document.body.classList.remove('print-student');
  });
})();
</script>


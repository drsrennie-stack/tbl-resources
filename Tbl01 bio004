<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Atkinson+Hyperlegible:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0A1322;
    --gold:#D4A24C;
    --terra:#C25A3E;
    --terra-text:#7A2F18;
    --teal-text:#2C5F66;
    --ink-soft:#14202F;
    --rule-soft:#DCE0E6;
    --navy-tint:#EDF1F3;
    --navy-complete:#1E3D4C;
    --white:#ffffff;
    --offwhite:#fafaf9;
    --shadow-card:0 1px 2px rgba(10,19,34,0.05);
    --shadow-hover:0 6px 16px rgba(10,19,34,0.10), 0 3px 6px rgba(10,19,34,0.06);
    --jakarta:'Plus Jakarta Sans',system-ui,sans-serif;
    --reading:'Atkinson Hyperlegible','Plus Jakarta Sans',system-ui,sans-serif;
    --dmsans:'DM Sans','Plus Jakarta Sans',system-ui,sans-serif;
  }

  *,*::before,*::after{box-sizing:border-box;}
  em,i,cite,dfn,var,address{font-style:normal;}

  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--white);
    color:var(--ink-soft);
    font-family:var(--jakarta);
    font-size:16px;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }

  .wrap{max-width:980px;margin:0 auto;padding:0 20px 80px;}

  a{color:var(--teal-text);}
  a:focus-visible,button:focus-visible,input:focus-visible,
  summary:focus-visible,.pill:focus-visible{
    outline:3px solid var(--gold);
    outline-offset:2px;
  }

  .skip{
    position:absolute;left:-9999px;top:0;background:var(--navy);color:var(--white);
    padding:10px 16px;z-index:200;border-radius:4px;
  }
  .skip:focus{left:12px;top:12px;}

  /* ===== HEADER ===== */
  .masthead{
    background:var(--navy);
    color:var(--white);
    padding:38px 24px 34px;
    border-bottom:4px solid var(--gold);
  }
  .masthead .inner{max-width:980px;margin:0 auto;}
  .brandline{
    font-family:var(--dmsans);
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--gold);
    margin:0 0 16px;
    font-weight:600;
  }
  .masthead h1{
    font-family:var(--jakarta);
    font-weight:800;
    font-size:clamp(28px,5vw,42px);
    line-height:1.08;
    margin:0 0 14px;
    letter-spacing:-0.01em;
  }
  .meta-line{
    display:flex;flex-wrap:wrap;gap:10px 26px;
    font-family:var(--dmsans);
    font-size:14px;
    color:#cdd6df;
    border-top:1px solid rgba(255,255,255,0.16);
    padding-top:16px;
    margin-top:4px;
  }
  .meta-line span b{color:var(--white);font-weight:600;}
  .meta-line .label{
    text-transform:uppercase;letter-spacing:0.1em;font-size:11px;
    color:var(--gold);display:block;margin-bottom:2px;
  }

  /* ===== TOOLBAR ===== */
  .toolbar{
    position:sticky;top:0;z-index:120;
    background:var(--white);
    border-bottom:1px solid var(--rule-soft);
    box-shadow:var(--shadow-card);
  }
  .toolbar .inner{
    max-width:980px;margin:0 auto;padding:10px 20px;
    display:flex;flex-wrap:wrap;align-items:center;gap:10px 14px;
  }
  .timer-box{
    display:flex;align-items:center;gap:8px;
    border:1px solid var(--rule-soft);border-radius:4px;
    padding:6px 8px;background:var(--offwhite);
  }
  .timer-readout{
    font-family:var(--jakarta);font-weight:800;font-size:20px;
    color:var(--navy);min-width:74px;text-align:center;
    font-variant-numeric:tabular-nums;
  }
  .timer-readout.warn{color:var(--terra);}
  .preset-row{display:flex;gap:6px;flex-wrap:wrap;}
  .btn{
    font-family:var(--jakarta);font-weight:700;font-size:13px;
    border-radius:4px;border:1px solid var(--navy);
    background:var(--navy);color:var(--white);
    padding:8px 12px;cursor:pointer;line-height:1;
    transition:transform .12s ease, box-shadow .12s ease;
  }
  .btn:hover{box-shadow:var(--shadow-hover);transform:translateY(-1px);}
  .btn.gold{background:var(--gold);border-color:var(--gold);color:var(--navy);}
  .btn.ghost{background:var(--white);color:var(--navy);}
  .btn.small{font-size:12px;padding:6px 9px;}
  .btn.preset{
    background:var(--white);color:var(--navy);border-color:var(--rule-soft);
    font-weight:600;font-size:12px;padding:6px 9px;
  }
  .btn.preset.active{background:var(--navy);color:var(--white);border-color:var(--navy);}
  .toolbar-spacer{flex:1 1 auto;}

  /* ===== NAV PILLS ===== */
  .pillnav{
    max-width:980px;margin:18px auto 0;padding:0 20px;
    display:flex;flex-wrap:wrap;gap:8px;
  }
  .pill{
    font-family:var(--dmsans);font-weight:600;font-size:13px;
    border:1px solid var(--rule-soft);border-radius:99px;
    background:var(--white);color:var(--ink-soft);
    padding:7px 15px;cursor:pointer;line-height:1;
    transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease;
  }
  .pill:hover{border-color:var(--navy);box-shadow:var(--shadow-hover);transform:translateY(-1px);}

  /* ===== SECTIONS ===== */
  section{margin-top:46px;scroll-margin-top:140px;}
  .eyebrow{
    font-family:var(--dmsans);font-size:12px;letter-spacing:0.16em;
    text-transform:uppercase;color:var(--terra-text);font-weight:600;
    margin:0 0 6px;
  }
  h2{
    font-family:var(--jakarta);font-weight:800;font-size:26px;
    color:var(--navy);margin:0 0 8px;letter-spacing:-0.01em;
  }
  h3{
    font-family:var(--jakarta);font-weight:700;font-size:18px;
    color:var(--navy);margin:26px 0 10px;
  }
  .lead{font-family:var(--reading);font-size:16px;color:var(--ink-soft);margin:0 0 18px;max-width:72ch;}
  .reading{font-family:var(--reading);}

  .card{
    background:var(--white);border:1px solid var(--rule-soft);border-radius:4px;
    box-shadow:var(--shadow-card);padding:20px 22px;margin:14px 0;
  }
  .card.tint{background:var(--offwhite);}

  /* objectives */
  ol.objectives{list-style:none;counter-reset:lo;margin:0;padding:0;}
  ol.objectives li{
    counter-increment:lo;position:relative;
    padding:14px 16px 14px 56px;border:1px solid var(--rule-soft);
    border-radius:4px;background:var(--white);margin:10px 0;
    font-family:var(--reading);box-shadow:var(--shadow-card);
  }
  ol.objectives li::before{
    content:"LO" counter(lo);
    position:absolute;left:12px;top:12px;
    background:var(--navy);color:var(--white);
    font-family:var(--jakarta);font-weight:700;font-size:12px;
    padding:5px 7px;border-radius:4px;line-height:1;
  }

  /* prework */
  .prework-head{display:flex;flex-wrap:wrap;align-items:baseline;gap:12px;justify-content:space-between;}
  .progress-tag{
    font-family:var(--jakarta);font-weight:700;font-size:13px;color:var(--teal-text);
    border:1px solid var(--rule-soft);border-radius:99px;padding:6px 14px;background:var(--offwhite);
  }
  .pw-item{
    display:grid;grid-template-columns:30px 1fr;gap:14px;
    border:1px solid var(--rule-soft);border-radius:4px;background:var(--white);
    padding:16px 18px;margin:10px 0;box-shadow:var(--shadow-card);
    transition:border-color .12s ease;
  }
  .pw-item.done{background:var(--navy-tint);border:1px solid var(--navy-complete);}
  .pw-item input[type=checkbox]{width:22px;height:22px;margin-top:2px;accent-color:var(--navy-complete);cursor:pointer;}
  .pw-body h4{font-family:var(--jakarta);font-weight:700;font-size:15px;margin:0 0 4px;color:var(--navy);}
  .pw-body .crit{font-family:var(--reading);font-size:14px;margin:6px 0 0;color:var(--ink-soft);}
  .pw-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;}
  .chip{
    font-family:var(--dmsans);font-size:11px;font-weight:600;letter-spacing:0.04em;
    border-radius:99px;padding:4px 10px;background:var(--offwhite);
    border:1px solid var(--rule-soft);color:var(--teal-text);
  }
  .chip.time{background:var(--navy);color:var(--white);border-color:var(--navy);}

  /* RAT questions */
  .q{
    border:1px solid var(--rule-soft);border-radius:4px;background:var(--white);
    padding:18px 20px;margin:14px 0;box-shadow:var(--shadow-card);
  }
  .q .qhead{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .qnum{
    font-family:var(--jakarta);font-weight:800;font-size:14px;color:var(--white);
    background:var(--navy);border-radius:4px;padding:5px 9px;line-height:1;
  }
  .dok{
    font-family:var(--dmsans);font-size:11px;font-weight:600;letter-spacing:0.06em;
    text-transform:uppercase;border-radius:99px;padding:4px 10px;
    border:1px solid var(--rule-soft);color:var(--teal-text);background:var(--offwhite);
  }
  .qtopic{font-family:var(--dmsans);font-size:12px;color:var(--terra-text);font-weight:600;margin-left:auto;}
  .q .stem{font-family:var(--reading);font-size:15.5px;margin:0 0 12px;}
  ol.opts{list-style:none;margin:0;padding:0;counter-reset:opt;}
  ol.opts li{
    counter-increment:opt;position:relative;padding:9px 12px 9px 42px;
    border:1px solid var(--rule-soft);border-radius:4px;margin:7px 0;
    font-family:var(--reading);font-size:14.5px;background:var(--white);
  }
  ol.opts li::before{
    content:counter(opt,upper-alpha);
    position:absolute;left:10px;top:8px;
    font-family:var(--jakarta);font-weight:700;font-size:13px;color:var(--navy);
    border:1px solid var(--rule-soft);border-radius:4px;width:22px;height:22px;
    display:flex;align-items:center;justify-content:center;background:var(--offwhite);
  }

  .callout{
    border-left:4px solid var(--gold);background:var(--offwhite);
    border-radius:4px;padding:14px 18px;margin:16px 0;font-family:var(--reading);
  }
  .callout.terra{border-left-color:var(--terra);}
  .callout.navy{border-left-color:var(--navy);}
  .callout h4{font-family:var(--jakarta);font-weight:700;font-size:14px;margin:0 0 6px;color:var(--navy);text-transform:none;}

  /* application */
  .stimulus{border:1px solid var(--navy);border-radius:4px;background:var(--navy-tint);padding:20px 22px;}
  .stimulus h3{margin-top:0;}
  .vitals{font-family:var(--dmsans);font-size:13px;display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:8px 18px;margin-top:12px;}
  .vitals div{border-top:1px solid var(--rule-soft);padding-top:6px;}
  .vitals .label{display:block;text-transform:uppercase;letter-spacing:0.08em;font-size:10px;color:var(--teal-text);font-weight:600;}

  .choice-options{display:grid;gap:10px;margin:12px 0;}
  .choice{
    border:1px solid var(--rule-soft);border-radius:4px;padding:14px 16px;background:var(--white);
    box-shadow:var(--shadow-card);
  }
  .choice .clabel{font-family:var(--jakarta);font-weight:700;color:var(--navy);font-size:15px;}
  .choice .cdesc{font-family:var(--reading);font-size:14px;margin-top:4px;}

  .branch{border:1px solid var(--rule-soft);border-radius:4px;padding:16px 18px;margin:10px 0;background:var(--white);box-shadow:var(--shadow-card);}
  .branch .btag{font-family:var(--dmsans);font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--terra-text);}
  .branch h4{font-family:var(--jakarta);font-weight:700;font-size:15px;margin:4px 0 8px;color:var(--navy);}

  table.s{width:100%;border-collapse:collapse;font-family:var(--reading);font-size:14px;margin:12px 0;}
  table.s th,table.s td{border:1px solid var(--rule-soft);padding:9px 11px;text-align:left;vertical-align:top;}
  table.s th{background:var(--navy);color:var(--white);font-family:var(--jakarta);font-weight:600;font-size:13px;}
  table.s tr:nth-child(even) td{background:var(--offwhite);}

  /* facilitation timeline */
  ul.timeline{list-style:none;margin:0;padding:0;}
  ul.timeline li{
    display:grid;grid-template-columns:96px 1fr;gap:14px;align-items:start;
    border-left:2px solid var(--rule-soft);padding:10px 0 10px 16px;margin-left:6px;
  }
  ul.timeline li .clock{font-family:var(--jakarta);font-weight:800;color:var(--navy);font-size:14px;font-variant-numeric:tabular-nums;}
  ul.timeline li .what{font-family:var(--reading);font-size:14.5px;}
  ul.timeline li .what b{font-family:var(--jakarta);font-weight:700;color:var(--navy);}

  ul.plain{font-family:var(--reading);padding-left:20px;}
  ul.plain li{margin:7px 0;}

  /* answer center reveal */
  .reveal-bar{
    border:1px dashed var(--rule-soft);border-radius:4px;background:var(--offwhite);
    padding:22px;text-align:center;margin:14px 0;
  }
  .reveal-bar p{font-family:var(--reading);margin:0 0 12px;color:var(--teal-text);}
  #answerCenter[hidden]{display:none;}

  .keytable th,.keytable td{text-align:center;}
  .keytable td.concept{text-align:left;font-size:13px;}
  .ans{font-family:var(--jakarta);font-weight:800;color:var(--navy);font-size:16px;}

  .ratq{border:1px solid var(--rule-soft);border-radius:4px;padding:16px 18px;margin:12px 0;background:var(--white);}
  .ratq .rq-stem{font-family:var(--jakarta);font-weight:700;color:var(--navy);font-size:15px;margin:0 0 6px;}
  .ratq .correct{font-family:var(--reading);font-size:14px;border-left:4px solid var(--navy-complete);background:var(--navy-tint);padding:8px 12px;border-radius:4px;margin:8px 0;}
  .ratq ul.why{list-style:none;margin:8px 0 0;padding:0;font-family:var(--reading);font-size:13.5px;}
  .ratq ul.why li{padding:6px 0;border-top:1px solid var(--rule-soft);}
  .ratq ul.why li b{color:var(--terra-text);}

  footer{margin-top:60px;border-top:1px solid var(--rule-soft);padding-top:22px;font-family:var(--dmsans);font-size:12.5px;color:var(--teal-text);}

  /* ===== PRINT SCOPING ===== */
  @media print{
    .toolbar,.pillnav,.skip,.reveal-bar,.btn{display:none !important;}
    body{font-size:12px;}
    section{margin-top:24px;page-break-inside:auto;}
    .q,.pw-item,.ratq,.branch,.card{page-break-inside:avoid;}
    .masthead{border-bottom:3px solid var(--gold);-webkit-print-color-adjust:exact;print-color-adjust:exact;}
    .masthead,.qnum,table.s th,.chip.time,ol.objectives li::before{-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  }
  body.print-student #facilitation,
  body.print-student #answerCenter{display:none !important;}
  @media print{
    body.print-student #facilitation,
    body.print-student #answerCenter{display:none !important;}
  }

  @media (max-width:640px){
    .meta-line{flex-direction:column;gap:12px;}
    ul.timeline li{grid-template-columns:72px 1fr;}
  }
  @media (prefers-reduced-motion:reduce){
    *{transition:none !important;scroll-behavior:auto !important;}
  }
</style>
